# URL do backend (obrigatório na Vercel)
# Ex.: https://seu-backend.railway.app ou https://api.seudominio.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# VSL linear (MP4): use UMA das opções abaixo — prioridade: URL direta > Cloudinary > embed.

# A) URL completa (pode colar o "Copy URL" do Cloudinary, ou qualquer CDN)
# NEXT_PUBLIC_VSL_DIRECT_VIDEO_URL=https://res.cloudinary.com/SEU_CLOUD/video/upload/v123/pasta/vsl.mp4

# B) Cloudinary sem colar URL inteira (public ID = caminho no Media Library, ex.: pasta/nome-do-video.mp4)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=seu_cloud_name
# NEXT_PUBLIC_VSL_CLOUDINARY_PUBLIC_ID=pasta/vsl-vertical.mp4
# Opcional: transformações (ex.: q_auto:good , c_limit,h_1920,w_1080,f_mp4)
# NEXT_PUBLIC_VSL_CLOUDINARY_TRANSFORM=q_auto:good

# C) Embed (YouTube, Vimeo…) — só se não houver vídeo direto
# NEXT_PUBLIC_VSL_EMBED_URL=https://www.youtube.com/embed/SEU_ID
